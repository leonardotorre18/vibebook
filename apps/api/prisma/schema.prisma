// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  email String @unique
  name String
  lastname String
  passwordHash String @map("password_hash")


  posts Post[]
  postComments PostComment[]
  postLikes PostLike[]
  postBookmarks PostBookmark[]


  codes Code[]
  commentLikes CommentLike[]


  friendshipRequestSender FriendshipRequest[] @relation("friendship_request_sender")
  friendshipRequestReceiver FriendshipRequest[] @relation("friendship_request_receiver")


  friendshipSender Friendship[] @relation("friendship_sender")
  friendshipReceiver Friendship[] @relation("friendship_receiver")


  @@map("users")
}


model FriendshipRequest {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  status String @default("PENDING")


  senderId String @map("sender_id")
  sender User @relation("friendship_request_sender", fields: [senderId], references: [id])


  receiverId String @map("receiver_id")
  receiver User @relation("friendship_request_receiver", fields: [receiverId], references: [id])


  @@unique([senderId, receiverId])
  @@map("friendship_requests")
}


model Friendship {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  senderId String @map("sender_id")
  sender User @relation("friendship_sender", fields: [senderId], references: [id])


  receiverId String @map("receiver_id")
  receiver User @relation("friendship_receiver", fields: [receiverId], references: [id])


  @@unique([senderId, receiverId])
  @@map("friendships")
}


model Post {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  body String
  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  media PostMedia[]
  comments PostComment[]
  likes PostLike[]
  bookmarks PostBookmark[]


  @@map("posts")
}


model Code {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  codeHash String @map("code_hash")


  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  attempts Int
  purpose String


  @@map("codes")
}


model PostMedia {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  postId String @map("post_id")
  post Post @relation(fields: [postId], references: [id])


  url String
  mediaType String @map("media_type")
  thumbnailUrl String? @map("thumbnail_url")
  durationSeconds Int? @map("duration_in_seconds")
  storageKey String @map("storage_key")
  width Int
  height Int
  displayOrder Int @default(0) @map("display_order")
  fileSizeBytes Int @map("file_size_bytes")


  @@map("post_media")
}


model PostComment {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  postId String @map("post_id")
  post Post @relation(fields: [postId], references: [id])


  likes CommentLike[]


  @@map("post_comments")
}


model CommentLike {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  commentId String @map("comment_id")
  comment PostComment @relation(fields: [commentId], references: [id])


  @@unique([userId, commentId])
  @@map("comment_likes")
}


model PostLike {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  postId String @map("post_id")
  post Post @relation(fields: [postId], references: [id])


  @@unique([userId, postId])
  @@map("post_likes")
}


model PostBookmark {
  id String @id @default(ulid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")


  userId String @map("user_id")
  user User @relation(fields: [userId], references: [id])


  postId String @map("post_id")
  post Post @relation(fields: [postId], references: [id])


  @@unique([userId, postId])
  @@map("post_bookmarks")
}


